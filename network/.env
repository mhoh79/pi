# ---------------------------------------------------------------------------
# Environment configuration for the multi-node RPi simulation network.
# Consumed by docker-compose.yml (env_file) and by Python code (os.environ).
# ---------------------------------------------------------------------------

# Docker / build target platform
PLATFORM=linux/arm/v7

# Required when the Docker CLI version exceeds the daemon's max API version
DOCKER_API_VERSION=1.43

# Transport layer: http | mqtt | opcua
# Switch to mqtt once the mosquitto service is uncommented and
# asyncio-mqtt is installed in the sensor/gateway images.
TRANSPORT=http

# How often each sensor node reads and publishes a sample (milliseconds)
SENSOR_INTERVAL_MS=1000

# Gateway coordinates (used by sensor nodes, PLC, and HMI)
GATEWAY_HOST=gateway
GATEWAY_PORT=8080

# PLC coordinates (used by HMI)
PLC_HOST=plc
PLC_PORT=8081

# PLC scan-cycle period (milliseconds)
PLC_SCAN_CYCLE_MS=500

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
